@page "/"
@inject HttpClient Http

<PageTitle>Home</PageTitle>

<h1>Teams Management</h1>

<p>Welcome to the Blazor WebAssembly application for managing football teams.</p>

<div class="alert alert-info">
    <strong>Quick Stats:</strong> Displaying teams from the API
</div>

@if (teams == null)
{
    <p><em>Loading teams...</em></p>
}
else
{
    <h3>Teams (Total: @teams.Length)</h3>

    <div class="row">
        @foreach (var team in teams)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@team.Name</h5>
                        <p class="card-text">Team ID: @team.Id</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <p class="mt-3">
        <a href="/teams" class="btn btn-primary">View All Teams</a>
    </p>
}

@code {
    private KooliProjekt.BlazorApp.Models.Team[]? teams;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            teams = await Http.GetFromJsonAsync<KooliProjekt.BlazorApp.Models.Team[]>("Teams");
        }
        catch (Exception ex)
        {
            // Handle error - in production, use proper error handling
            Console.WriteLine($"Error loading teams: {ex.Message}");
            teams = Array.Empty<KooliProjekt.BlazorApp.Models.Team>();
        }
    }
}
