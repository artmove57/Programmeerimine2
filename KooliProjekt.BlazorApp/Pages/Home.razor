@page "/"
@inject IApiClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using KooliProjekt.BlazorApp.API

<PageTitle>Home</PageTitle>

<h1>Teams Management</h1>

<p>Welcome to the Blazor WebAssembly application for managing football teams.</p>

<div class="alert alert-info">
    <strong>Quick Stats:</strong> Displaying teams from the API
</div>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CreateNew">
        <span class="bi bi-plus-circle"></span> New Team
    </button>
</div>

@if (teams == null)
{
    <p><em>Loading teams...</em></p>
}
else if (!teams.Any())
{
    <div class="alert alert-warning">
        No teams found. Click "New Team" to add one.
    </div>
}
else
{
    <h3>Teams (Total: @teams.Count)</h3>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var team in teams)
            {
                <tr>
                    <td>@team.Id</td>
                    <td>@team.Name</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-2" @onclick="() => Edit(team.Id)">
                            <span class="bi bi-pencil"></span> Edit
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(team)">
                            <span class="bi bi-trash"></span> Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">
        @errorMessage
    </div>
}

@code {
    private List<KooliProjekt.BlazorApp.Models.Team>? teams;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var result = await ApiClient.GetAllAsync();

            if (result.IsSuccess)
            {
                teams = result.Data;
                errorMessage = null;
            }
            else
            {
                errorMessage = result.ErrorMessage;
                teams = new List<KooliProjekt.BlazorApp.Models.Team>();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading teams: {ex.Message}";
            teams = new List<KooliProjekt.BlazorApp.Models.Team>();
        }
    }

    private void CreateNew()
    {
        Navigation.NavigateTo("/edit/0");
    }

    private void Edit(int id)
    {
        Navigation.NavigateTo($"/edit/{id}");
    }

    private async Task Delete(KooliProjekt.BlazorApp.Models.Team team)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete team '{team.Name}'?"))
        {
            var result = await ApiClient.DeleteAsync(team.Id);

            if (result.IsSuccess)
            {
                await LoadDataAsync();
            }
            else
            {
                errorMessage = result.ErrorMessage;
            }
        }
    }
}
