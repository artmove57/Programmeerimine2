@page "/edit/{Id:int}"
@inject IApiClient ApiClient
@inject NavigationManager Navigation
@using KooliProjekt.BlazorApp.API
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>@(Id == 0 ? "New Team" : "Edit Team")</PageTitle>

<h1>@(Id == 0 ? "Create New Team" : $"Edit Team #{Id}")</h1>

<div class="row">
    <div class="col-md-6">
        <EditForm EditContext="@editContext" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="id" class="form-label">ID:</label>
                <input type="text" class="form-control" id="id" value="@team.Id" disabled />
            </div>

            <div class="mb-3">
                <label for="name" class="form-label">Name:</label>
                <InputText @bind-Value="team.Name" class="form-control" id="name" />
                <ValidationMessage For="@(() => team.Name)" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">
                    <h5>Errors:</h5>
                    <p>@errorMessage</p>
                </div>
            }

            <div class="mb-3">
                <button type="submit" class="btn btn-success me-2" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span class="bi bi-check-circle me-1"></span>
                        <span>Save</span>
                    }
                </button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">
                    <span class="bi bi-x-circle me-1"></span> Cancel
                </button>
            </div>
        </EditForm>
    </div>

    <div class="col-md-6">
        <div class="card bg-light">
            <div class="card-header">
                <h5>Validation Rules</h5>
            </div>
            <div class="card-body">
                <ul>
                    <li><strong>Name:</strong> Required</li>
                    <li><strong>Name Length:</strong> 2-50 characters</li>
                </ul>
                <p class="text-muted mt-2">
                    <small>
                        ✅ Client-side validation (Blazor)<br />
                        ✅ Server-side validation (API)
                    </small>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private KooliProjekt.BlazorApp.Models.Team team = new();
    private EditContext? editContext;
    private ValidationMessageStore? messageStore;
    private string? errorMessage;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id == 0)
        {
            // Create new team
            team = new KooliProjekt.BlazorApp.Models.Team { Id = 0, Name = string.Empty };
        }
        else
        {
            // Load existing team
            await LoadTeamAsync();
        }

        // Initialize EditContext and ValidationMessageStore
        editContext = new EditContext(team);
        messageStore = new ValidationMessageStore(editContext);

        // Clear validation messages when field changes
        editContext.OnFieldChanged += (sender, args) =>
        {
            messageStore.Clear(args.FieldIdentifier);
            errorMessage = null;
        };
    }

    private async Task LoadTeamAsync()
    {
        var result = await ApiClient.GetByIdAsync(Id);

        if (result.IsSuccess)
        {
            team = result.Data!;
            errorMessage = null;
        }
        else
        {
            errorMessage = result.ErrorMessage;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (editContext == null || messageStore == null)
            return;

        isSaving = true;
        errorMessage = null;

        // Clear previous validation errors
        messageStore.Clear();

        try
        {
            if (Id == 0)
            {
                // Create new team
                var result = await ApiClient.CreateAsync(team);

                if (result.IsSuccess)
                {
                    Navigation.NavigateTo("/");
                }
                else
                {
                    HandleApiErrors(result);
                }
            }
            else
            {
                // Update existing team
                var result = await ApiClient.UpdateAsync(Id, team);

                if (result.IsSuccess)
                {
                    Navigation.NavigateTo("/");
                }
                else
                {
                    HandleApiErrors(result);
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving team: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    /// <summary>
    /// Handle API errors - add server validation errors to EditContext
    /// This makes server-side validation errors appear in Blazor ValidationMessage components
    /// </summary>
    private void HandleApiErrors(Result result)
    {
        if (result.HasValidationErrors && messageStore != null && editContext != null)
        {
            // Add server validation errors to ValidationMessageStore
            foreach (var error in result.Errors)
            {
                var fieldName = error.Key;
                var errors = error.Value;

                // Create FieldIdentifier for the field
                var fieldIdentifier = editContext.Field(fieldName);

                // Add all error messages for this field
                foreach (var errorMsg in errors)
                {
                    messageStore.Add(fieldIdentifier, errorMsg);
                }
            }

            // Notify EditContext that validation state changed
            editContext.NotifyValidationStateChanged();

            errorMessage = "Please fix the validation errors above";
        }
        else
        {
            // General error
            errorMessage = result.ErrorMessage;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/");
    }
}
