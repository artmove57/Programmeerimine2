@page "/matches"
@inject IApiClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using KooliProjekt.BlazorApp.API
@using KooliProjekt.BlazorApp.Models

<PageTitle>Matches</PageTitle>

<h1>Matches</h1>

<p>Manage all matches with teams and tournaments.</p>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CreateNew">
        <span class="bi bi-plus-circle"></span> New Match
    </button>
</div>

@if (matches == null)
{
    <p><em>Loading matches...</em></p>
}
else if (!matches.Any())
{
    <div class="alert alert-warning">
        No matches found. Click "New Match" to add one.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Total Points</th>
                <th>Team</th>
                <th>Tournament</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var match in matches)
            {
                <tr>
                    <td>@match.Id</td>
                    <td>@match.Name</td>
                    <td>@match.StartData</td>
                    <td>@match.EndData</td>
                    <td>@match.TotalPoints</td>
                    <td>@match.Team?.Name</td>
                    <td>@match.Tournament?.Name</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-2" @onclick="() => Edit(match.Id)">
                            <span class="bi bi-pencil"></span> Edit
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(match)">
                            <span class="bi bi-trash"></span> Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">
        <strong>Error:</strong> @errorMessage
    </div>
}

@code {
    private List<Match>? matches;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var result = await ApiClient.GetAllMatchesAsync();
            
            if (result.IsSuccess)
            {
                matches = result.Data;
                errorMessage = null;
            }
            else
            {
                errorMessage = result.ErrorMessage;
                matches = new List<Match>();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading matches: {ex.Message}";
            matches = new List<Match>();
        }
    }

    private void CreateNew()
    {
        Navigation.NavigateTo("/matches/edit/0");
    }

    private void Edit(int id)
    {
        Navigation.NavigateTo($"/matches/edit/{id}");
    }

    private async Task Delete(Match match)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete match '{match.Name}'?"))
        {
            var result = await ApiClient.DeleteMatchAsync(match.Id);
            
            if (result.IsSuccess)
            {
                await LoadDataAsync();
            }
            else
            {
                errorMessage = result.ErrorMessage;
            }
        }
    }
}
